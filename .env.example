FRONTIERLENS_ENV=production
FRONTIERLENS_ADMIN_TOKEN=replace-with-at-least-24-random-characters
FRONTIERLENS_PUBLIC_BASE_URL=https://frontierlens.example.com
FRONTIERLENS_DATA_DIR=/app/data
FRONTIERLENS_REQUEST_TIMEOUT=30
FRONTIERLENS_MAX_DOWNLOAD_BYTES=100663296
FRONTIERLENS_MAX_SCAN_DOWNLOADS=10
FRONTIERLENS_AI_API_KEY=replace-with-server-side-api-key
FRONTIERLENS_AI_BASE_URL=https://api.openai.com/v1
FRONTIERLENS_AI_MODEL=gpt-5.6-luna
